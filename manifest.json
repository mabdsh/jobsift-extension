{
  "manifest_version": 3,
  "name": "Rolevance \u2014 Smart Job Matching",
  "version": "5.0.0",
  "description": "Score every LinkedIn and Indeed job against your profile instantly. Find roles that actually fit \u2014 powered by AI matching.",
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "*://*.indeed.com/*",
    "https://YOUR_SUBDOMAIN.duckdns.org/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "Rolevance"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "*://*.indeed.com/*"
      ],
      "js": [
        "content/scraper.js",
        "content/scorer.js",
        "content/panel.js",
        "content/injector.js",
        "content/observer.js",
        "content/ai-analyzer.js",
        "content/tracker.js",
        "content/content.js"
      ],
      "css": [
        "assets/styles/badge.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}