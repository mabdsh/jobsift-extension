{
  "manifest_version": 3,
  "name": "JobSift — Smart Job Matching",
  "version": "3.1.0",
  "description": "Score every LinkedIn job against your profile instantly. Find the right roles faster with AI-powered matching.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://YOUR_SUBDOMAIN.duckdns.org/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "assets/icons/icon16.png",
      "32":  "assets/icons/icon32.png",
      "48":  "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "JobSift"
  },
  "icons": {
    "16":  "assets/icons/icon16.png",
    "32":  "assets/icons/icon32.png",
    "48":  "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": [
        "content/scraper.js",
        "content/scorer.js",
        "content/panel.js",
        "content/injector.js",
        "content/observer.js",
        "content/ai-analyzer.js",
        "content/content.js"
      ],
      "css": ["assets/styles/badge.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
